# Porta onde o servidor vai rodar localmente
PORT=3000

# Endereço de conexão com o banco de dados de desenvolvimento
DATABASE_URL="postgresql://usuario:senha@localhost:5432/taskmanager"

# Endereço de conexão com o banco de dados usado nos testes automatizados
TEST_DATABASE_URL="postgresql://usuario:senha@localhost:5432/taskmanager_test"

# Chave secreta usada para assinar e validar os tokens JWT de autenticação
JWT_SECRET="seu_segredo_longo_e_aleatorio_aqui"

# Tempo de expiração do token JWT (ex: 1h, 1d, 7d)
JWT_EXPIRES_IN="1d"
